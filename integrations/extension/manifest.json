{
  "manifest_version": 3,
  "name": "Bastion Wallet (web-connect)",
  "version": "0.1.0",
  "description": "Connect dApps in your browser to the local Bastion wallet via EIP-6963 / EIP-1193.",
  "permissions": ["nativeMessaging", "storage"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Bastion Wallet" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inpage.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
